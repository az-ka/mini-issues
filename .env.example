# =============================================================================
# MINI ISSUES — Environment Variables
# Salin file ini menjadi .env.local lalu isi nilainya
# =============================================================================

# -----------------------------------------------------------------------------
# CONVEX
# Dapatkan dari: https://dashboard.convex.dev → project Anda → Settings → URL & Deploy Key
# Format: https://xxxx.convex.cloud
# -----------------------------------------------------------------------------
PUBLIC_CONVEX_URL=

# -----------------------------------------------------------------------------
# CONVEX DEPLOY KEY — untuk deploy Convex functions (production / CI)
# Dapatkan dari: https://dashboard.convex.dev → project Anda → Settings → Deploy Key
# Catatan: Hanya dibutuhkan saat deploy (Vercel build), TIDAK perlu di .env.local dev
# -----------------------------------------------------------------------------
CONVEX_DEPLOY_KEY=

# -----------------------------------------------------------------------------
# CLERK — Authentication
# Dapatkan dari: https://dashboard.clerk.com → API Keys → Publishable key
# Format: pk_test_... (development) atau pk_live_... (production)
# -----------------------------------------------------------------------------
PUBLIC_CLERK_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# GEMINI AI — untuk fitur chat AI
# Dapatkan dari: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# GROQ AI — fallback ketika semua Gemini model kena rate limit (opsional)
# Dapatkan dari: https://console.groq.com/keys
# Kosongkan jika tidak ingin menggunakan Groq
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# TRELLO — Integrasi buat & update kartu
#
# TRELLO_API_KEY  → https://trello.com/power-ups/admin → Power-Up Anda → API Key tab
# TRELLO_TOKEN    → Di halaman yang sama, klik link "Token" di samping API Key
# TRELLO_LIST_ID  → Buka board Trello, tambahkan .json di akhir URL board,
#                   cari "lists" → salin "id" dari list yang ingin digunakan
#                   Contoh: https://trello.com/b/xxxxx/nama-board.json
# -----------------------------------------------------------------------------
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=

# =============================================================================
# CONVEX DASHBOARD ENVIRONMENT VARIABLES
# Variabel di bawah ini TIDAK diletakkan di .env.local — harus diset di:
# https://dashboard.convex.dev → project Anda → Settings → Environment Variables
# =============================================================================
#
# CLERK_JWT_ISSUER_DOMAIN
#   → Clerk Dashboard → Configure → Domains → Frontend API URL
#   → Format: https://verb-noun-00.clerk.accounts.dev (dev)
#             https://clerk.yourdomain.com (production)
#
# ADMIN_EMAILS
#   → Email(s) yang mendapat akses admin secara otomatis
#   → Satu email: admin@example.com
#   → Beberapa email (pisahkan dengan koma): admin@example.com,dev@example.com
#
